# Kineva — TestFlight automation.
require "spaceship"
#
# Quick start:
#   1. Put your App Store Connect API key creds in fastlane/.env (gitignored) — see .env.example.
#   2. One-time, create/verify signing identifiers:                   bundle exec fastlane setup_signing
#   3. If needed, create the App Store Connect app record manually with bundle id com.aretetechnologies.kineva,
#      then verify Fastlane can see it:                               bundle exec fastlane setup_app
#   4. Ship a build:                                                  bundle exec fastlane beta
#
# Notes for this repo:
#   • Strand.xcodeproj is GENERATED from project.yml by XcodeGen, so every build lane regenerates it
#     first (`generate`) to guarantee the archive matches the committed config.
#   • The version (MARKETING_VERSION) and build number (CURRENT_PROJECT_VERSION) live in project.yml,
#     NOT the pbxproj — so `bump` edits project.yml then regenerates. TestFlight rejects a build whose
#     number was already uploaded, so bump before re-shipping the same marketing version.
#   • Signing is Automatic (team 7A97GB45TD). Archiving with -allowProvisioningUpdates lets Xcode mint
#     /refresh the Apple Distribution cert + App Store profiles for the app and every embedded target
#     (widgets, watch, complications), authenticated by the same API key — no Match repo required.

default_platform(:ios)

APP_NAME = "Kineva".freeze
APP_IDENTIFIER = "com.aretetechnologies.kineva".freeze
APP_GROUP_ID = "group.com.aretetechnologies.kineva".freeze
SCHEME = "KinevaiOS".freeze
TEAM_ID = "7A97GB45TD".freeze
PROJECT_YML = "../project.yml".freeze

BUNDLE_IDS = {
  APP_IDENTIFIER => [
    Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS,
    Spaceship::ConnectAPI::BundleIdCapability::Type::HEALTHKIT
  ],
  "#{APP_IDENTIFIER}.widgets" => [
    Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
  ],
  "#{APP_IDENTIFIER}.watch" => [
    Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS,
    Spaceship::ConnectAPI::BundleIdCapability::Type::HEALTHKIT
  ],
  "#{APP_IDENTIFIER}.watch.complications" => [
    Spaceship::ConnectAPI::BundleIdCapability::Type::APP_GROUPS
  ]
}.freeze

BUNDLE_ID_NAMES = {
  APP_IDENTIFIER => APP_NAME,
  "#{APP_IDENTIFIER}.widgets" => "#{APP_NAME} Widgets",
  "#{APP_IDENTIFIER}.watch" => "#{APP_NAME} Watch",
  "#{APP_IDENTIFIER}.watch.complications" => "#{APP_NAME} Watch Complications"
}.freeze

# Build an App Store Connect API key token from the env (.p8 + key id + issuer id).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.absolute_path(ENV.fetch("ASC_KEY_PATH")),
    in_house: false
  )
end

# xcodebuild flags that let Automatic signing create/refresh distribution assets non-interactively,
# authenticated by the API key (Xcode 13+ / our Xcode 26).
def provisioning_xcargs
  [
    "-allowProvisioningUpdates",
    "-authenticationKeyID", ENV.fetch("ASC_KEY_ID"),
    "-authenticationKeyIssuerID", ENV.fetch("ASC_ISSUER_ID"),
    "-authenticationKeyPath", File.absolute_path(ENV.fetch("ASC_KEY_PATH"))
  ].join(" ")
end

def marketing_version
  File.read(PROJECT_YML)[/MARKETING_VERSION:\s*"([^"]+)"/, 1] || "1.0"
end

def ensure_bundle_id(identifier)
  bundle_id = Spaceship::ConnectAPI::BundleId.find(identifier)
  return bundle_id if bundle_id

  UI.message("Creating Bundle ID #{identifier}")
  Spaceship::ConnectAPI::BundleId.create(
    name: BUNDLE_ID_NAMES.fetch(identifier),
    platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS,
    identifier: identifier
  )
end

def ensure_capability(bundle_id, capability_type)
  capabilities = bundle_id.get_capabilities
  return if capabilities.any? { |capability| capability.is_type?(capability_type) }

  UI.message("Enabling #{capability_type} for #{bundle_id.identifier}")
  bundle_id.create_capability(capability_type)
end

def ensure_signing_identifiers
  BUNDLE_IDS.each_with_object({}) do |(identifier, capabilities), created|
    bundle_id = ensure_bundle_id(identifier)
    capabilities.each { |capability| ensure_capability(bundle_id, capability) }
    created[identifier] = bundle_id
  end
end

def create_app_store_record(parent_bundle_id)
  Spaceship::ConnectAPI::App.create(
    name: APP_NAME,
    version_string: marketing_version,
    sku: ENV.fetch("APP_SKU", APP_IDENTIFIER),
    primary_locale: "en-US",
    bundle_id: parent_bundle_id.id,
    platforms: [Spaceship::ConnectAPI::Platform::IOS]
  )
rescue => e
  raise unless e.to_s.include?("resource 'apps' does not allow 'CREATE'") ||
               e.to_s.include?("does not allow 'CREATE'")

  UI.user_error!(
    "Bundle IDs and capabilities are ready, but this App Store Connect API key cannot create new app " \
    "records. Create the app manually in App Store Connect with bundle ID #{APP_IDENTIFIER}, or use " \
    "an App Store Connect account/key that has app-creation permission, then rerun `bundle exec fastlane setup_app`."
  )
end

platform :ios do
  desc "Regenerate Strand.xcodeproj from project.yml (XcodeGen is the source of truth)"
  lane :generate do
    Dir.chdir("..") { sh("xcodegen", "generate") }
  end

  desc "Bump the build number (CURRENT_PROJECT_VERSION) in project.yml, then regenerate the project"
  lane :bump do
    text = File.read(PROJECT_YML)
    current = text[/CURRENT_PROJECT_VERSION:\s*"(\d+)"/, 1].to_i
    raise "Couldn't find CURRENT_PROJECT_VERSION in project.yml" if current.zero?

    nextb = current + 1
    File.write(PROJECT_YML, text.sub(/CURRENT_PROJECT_VERSION:\s*"\d+"/,
                                     %(CURRENT_PROJECT_VERSION: "#{nextb}")))
    UI.success("Build number #{current} → #{nextb}")
    generate
  end

  desc "Create Bundle IDs and enable capabilities needed by automatic signing"
  lane :setup_signing do
    asc_api_key
    ensure_signing_identifiers
    UI.success("Bundle IDs and capabilities are ready for #{APP_IDENTIFIER}")
  end

  desc "Create Bundle IDs/capabilities and the App Store Connect app record (run once; safe to re-run)"
  lane :setup_app do
    asc_api_key
    bundle_ids = ensure_signing_identifiers

    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    if app
      UI.success("App Store Connect app already exists for #{APP_IDENTIFIER}")
    else
      UI.message("Creating App Store Connect app record for #{APP_IDENTIFIER}")
      create_app_store_record(bundle_ids.fetch(APP_IDENTIFIER))
      UI.success("Created App Store Connect app record for #{APP_IDENTIFIER}")
    end

    UI.important(
      "App Group #{APP_GROUP_ID} still has to exist on the Apple Developer team. " \
      "If Xcode automatic signing cannot create it during beta, create it manually in Certificates, Identifiers & Profiles."
    )
  end

  desc "Build a Release archive and upload it to TestFlight"
  lane :beta do
    key = asc_api_key
    generate

    build_app(
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Kineva.ipa",
      clean: true,
      xcargs: provisioning_xcargs,
      export_options: {
        signingStyle: "automatic",
        teamID: TEAM_ID
      }
    )

    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("Uploaded to TestFlight. Processing takes a few minutes; add testers in App Store Connect.")
  end
end
