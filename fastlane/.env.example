# App Store Connect API key credentials for fastlane.
#
# Create a key at: App Store Connect → Users and Access → Integrations → App Store Connect API
#   • Role: App Manager (or Admin) so it can upload builds and manage TestFlight.
#   • Download the AuthKey_XXXXXXXXXX.p8 ONCE (Apple won't let you re-download it).
#
# Then copy this file to fastlane/.env (which is gitignored) and fill in the values.
# NEVER commit the .p8 or the real .env.

ASC_KEY_ID=XXXXXXXXXX                                   # the Key ID shown next to the key
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx       # the Issuer ID at the top of the Integrations page
ASC_KEY_PATH=./secrets/AuthKey_XXXXXXXXXX.p8             # path to the downloaded .p8 (keep it out of git)
